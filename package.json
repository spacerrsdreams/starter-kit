{
  "name": "starter-kit",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean:install": "rm -rf .next && rm -rf node_modules && rm bun.lock && bun install",
    "prisma:reset": "dotenv -e .env.local -- prisma migrate reset",
    "prisma:format": "dotenv -e .env.local -- prisma format",
    "prisma:push": "dotenv -e .env.local -- prisma db push && dotenv -e .env.local -- prisma generate",
    "prisma:push:hard": "dotenv -e .env.local -- prisma db push --force-reset",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev && dotenv -e .env.local -- prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "bun prisma:migrate:deploy && bun prisma:generate",
    "prettier:format": "prettier --write .",
    "eslint:fix": "eslint --fix .",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "bun run build && bun run start",
    "lint": "tsc --noEmit && eslint",
    "env:push:development": "node scripts/vercel-env-push.js .env.development development",
    "env:push:preview": "node scripts/vercel-env-push.js .env.development preview",
    "env:push:all-pre-production": "bun env:push:development && bun env:push:preview",
    "env:push:production": "node scripts/vercel-env-push.js .env.production production",
    "env:push:one": "node scripts/vercel-env-push.js",
    "color:to-oklch": "node scripts/color-to-oklch.js",
    "create-starter-kit-app": "node packages/create-starter-kit-app/bin/create-starter-kit-app.js",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/billing/webhook"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-email/components": "^1.0.12",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/eslint-plugin-query": "^5.100.1",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@vercel/blob": "^2.3.3",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.168",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lenis": "^1.3.23",
    "lucide-react": "^1.11.0",
    "media-chrome": "^4.19.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.372.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.1",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.4.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "culori": "^4.0.2",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "6.0.3"
  }
}
