enum BlogPostLocale {
  EN
  DE
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String
  locale      BlogPostLocale @default(EN)
  preview     String
  seoKeywords String[]
  imageSrc    String
  content     Json
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([authorId])
  @@index([locale, createdAt])
  @@unique([slug, locale])
  @@map("blog_post")
}
