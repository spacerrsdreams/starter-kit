model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  preview     String
  seoKeywords String[]
  imageSrc    String
  content     Json
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([authorId])
  @@map("blog_post")
}
