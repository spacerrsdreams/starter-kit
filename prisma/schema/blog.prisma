model BlogPost {
  id        String   @id @default(cuid())
  title     String
  imageSrc  String
  content   Json
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([authorId])
  @@map("blog_post")
}
